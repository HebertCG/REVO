# REVO - Variables de entorno
# Copia este archivo como .env y ajusta valores en producción

# ─── PostgreSQL ───────────────────────────────
POSTGRES_DB=revo_db
POSTGRES_USER=revo_user
POSTGRES_PASSWORD=revo_pass_2025
DATABASE_URL=postgresql://revo_user:revo_pass_2025@postgres:5432/revo_db

# ─── Auth ─────────────────────────────────────
JWT_SECRET=revo_super_secret_jwt_key_2025_change_in_production
JWT_EXPIRE_HOURS=24

# ─── URLs internas (entre servicios) ──────────
AUTH_SERVICE_URL=http://auth-service:8001
SURVEY_SERVICE_URL=http://survey-service:8002
ML_SERVICE_URL=http://ml-service:8003

# ─── Frontend ─────────────────────────────────
VITE_AUTH_API=http://localhost:8001
VITE_SURVEY_API=http://localhost:8002
VITE_ML_API=http://localhost:8003
