# Configura estas variables en el Pánel de Vercel (Project Settings -> Environment Variables)
# Las URLs no deben llevar '/' al final.
# Ejemplo de Producción:
# VITE_AUTH_URL=https://revo-auth-service.onrender.com
# VITE_SURVEY_URL=https://revo-survey-service.onrender.com
# VITE_ML_URL=https://revo-ml-service.onrender.com

# Para Desarrollo (Local), déjalas comentadas o vacías para que actúe el proxy de vite.config.js
# VITE_AUTH_URL=
# VITE_SURVEY_URL=
# VITE_ML_URL=
